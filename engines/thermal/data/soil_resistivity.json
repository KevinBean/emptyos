    "moist_sand":         {"typical": 1.5,  "range": [1.3, 2.0],  "description": "Sand at field capacity"},
    "dry_sand":           {"typical": 2.5,  "range": [2.0, 3.5],  "description": "Aeolian / desert — high dry-out risk"},
    "wet_silt":           {"typical": 1.0,  "range": [0.8, 1.2],  "description": "Fine silt, water-saturated"},
    "moist_silt":         {"typical": 1.3,  "range": [1.0, 1.5],  "description": "Silt, partially saturated"},
    "dry_silt":           {"typical": 2.0,  "range": [1.5, 3.0],  "description": "Silt, drought conditions"},
    "bedrock_granite":    {"typical": 1.5,  "range": [1.0, 2.5],  "description": "Crystalline bedrock, varies with fracturing"},
