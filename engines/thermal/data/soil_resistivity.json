  "source": "IEC 60287-3-1 Table 1 + common engineering practice (CIGRE TB 880, IEEE Std 442)",
  "description": "Typical thermal resistivity (K·m/W) of soils and backfill materials. Values are nominal — site-specific measurements (thermal needle test per IEEE 442) are strongly preferred for any project where ampacity is load-bearing on this number. The IEC 60287 default of 1.0 K·m/W is appropriate for moist soils in temperate climates.",
  "rho_t_units": "K·m/W",
  "iec_60287_default": 1.0,
  "soil_types": {
    "very_wet_clay":      {"typical": 0.7,  "range": [0.6, 0.8],  "description": "Saturated, water table near surface"},
