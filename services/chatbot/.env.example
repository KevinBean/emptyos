# EmptyOS chatbot service — environment.
# Copy to `.env` and fill in. The deploy script reads this file via
# `docker compose --env-file .env`.

# Required: OpenAI API key for the LLM provider. Hold a budget cap on the
# OpenAI side too — defense in depth alongside the per-site daily_cap_usd
# enforced inside the service (sites.toml).
OPENAI_API_KEY=sk-...

# Required: token for /admin/* endpoints (Q&A curation, corpus refresh).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Must match `apps.publish.chatbot.admin_token` in the EmptyOS daemon's
# emptyos.toml so the publish app can talk to this service.
CHATBOT_ADMIN_TOKEN=

# Optional: where the SQLite ledger lives. Defaults to /data inside the
# container (mounted as the `chatbot-data` Docker volume in compose). Override
# only if you want the DB at a custom host path via bind mount.
# CHATBOT_DATA_DIR=/data

# Optional: where to read sites.toml. Defaults to /app/sites.toml (mounted
# read-only from this directory in compose). Don't override in normal use.
# CHATBOT_SITES_PATH=/app/sites.toml
