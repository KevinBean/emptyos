{
  "app": "cable",
  "endpoint": "/cable/api/rating/calculate",
  "description": "IEC 60287 cable current rating — validated against CIGRE TB 880 and IEC standards",
  "cases": [
    {
      "name": "TB880-0-1: 132kV 630Cu trefoil both-ends",
      "source": "CIGRE TB 880 Case 0-1, IEC 60287-1-1:2023",
      "input": {
        "conductor_material": "cu", "conductor_size": 630,
        "insulation": "xlpe", "voltage_kv": 132,
        "formation": "trefoil", "bonding": "both_ends",
        "num_circuits": 1, "burial_depth": 1.0,
        "soil_thermal_resistivity": 1.2, "ambient_temp": 25
      },
      "expected": {
        "preset_used":              {"not_null": true},
        "iteration.converged":      {"value": true},
        "iteration.n_iterations":   {"range": [2, 15]},
        "thermal.t1_insulation":    {"value": 0.4199, "abs": 0.001},
        "thermal.t3_oversheath":    {"value": 0.0867, "abs": 0.001},
        "thermal.t4_soil":          {"value": 0.758, "abs": 0.01},
        "dielectric.Wd_w_m":       {"value": 0.3851, "abs": 0.001},
        "sheath.lambda1":          {"value": 0.31, "abs": 0.02},
        "sheath.bonding":          {"value": "both_ends"},
        "conductor.diameter_mm":   {"value": 30.3, "abs": 0.1},
        "conductor.r_dc_ohm_m":   {"gt": 0},
        "cable.od_mm":             {"value": 75.5, "abs": 0.1},
        "base_rating_a":           {"range": [650, 720]},
        "max_conductor_temp":      {"value": 90}
      }
    },
    {
      "name": "Single-point: no circulating current",
      "source": "IEC 60287-1-1 §2.3 — single-point bonding eliminates circulating current",
      "input": {
        "conductor_material": "cu", "conductor_size": 630,
        "insulation": "xlpe", "voltage_kv": 132,
        "formation": "trefoil", "bonding": "single_point",
        "num_circuits": 1
      },
      "expected": {
        "sheath.lambda1":       {"value": 0, "abs": 0.001},
        "sheath.bonding":       {"value": "single_point"},
        "base_rating_a":        {"gt": 700},
        "iteration.converged":  {"value": true}
      }
    },
    {
      "name": "Cross-bonded: balanced cancellation",
      "source": "IEC 60287-1-1 §2.3.7 — balanced cross-bonding gives lambda1=0",
      "input": {
        "conductor_material": "cu", "conductor_size": 630,
        "insulation": "xlpe", "voltage_kv": 132,
        "formation": "trefoil", "bonding": "cross_bonded",
        "num_circuits": 1
      },
      "expected": {
        "sheath.lambda1":   {"value": 0, "abs": 0.001},
        "base_rating_a":    {"gt": 700}
      }
    },
    {
      "name": "Flat both-ends: per-cable lambda1",
      "source": "IEC 60287-1-1 §2.3.5 eqs 8-10 — flat formation per-cable sheath losses",
      "input": {
        "conductor_material": "cu", "conductor_size": 630,
        "insulation": "xlpe", "voltage_kv": 132,
        "formation": "flat", "bonding": "both_ends",
        "axial_spacing": 0.3, "num_circuits": 1
      },
      "expected": {
        "sheath.lambda1":                   {"gt": 1.0},
        "sheath.lambda1_per_cable":         {"not_null": true},
        "iteration.converged":              {"value": true},
        "base_rating_a":                    {"range": [300, 500]}
      }
    },
    {
      "name": "Flat: mutual heating present",
      "source": "IEC 60287-2-1 §4.2.3.2 — flat formation mutual heating",
      "input": {
        "conductor_material": "cu", "conductor_size": 630,
        "insulation": "xlpe", "voltage_kv": 132,
        "formation": "flat", "bonding": "single_point",
        "axial_spacing": 0.3, "num_circuits": 1
      },
      "expected": {
        "mutual_heating":                {"not_null": true},
        "mutual_heating.delta_theta_p":  {"gt": 5}
      }
    },
    {
      "name": "Duct: T4 breakdown present",
      "source": "IEC 60287-2-1 §4.2.7 — duct thermal decomposition",
      "input": {
        "conductor_material": "cu", "conductor_size": 630,
        "insulation": "xlpe", "voltage_kv": 132,
        "installation": "in_conduit", "conduit_material": "hdpe",
        "conduit_id_mm": 225, "num_circuits": 1
      },
      "expected": {
        "thermal.t4_breakdown":             {"not_null": true},
        "thermal.t4_breakdown.t4_air":      {"gt": 0.1},
        "thermal.t4_breakdown.t4_wall":     {"gt": 0.01},
        "thermal.t4_breakdown.t4_ext":      {"gt": 0.5},
        "thermal.t4_soil":                  {"gt": 1.0},
        "iteration.converged":              {"value": true}
      }
    },
    {
      "name": "Duct rating lower than direct buried",
      "source": "Duct adds T4'(air)+T4''(wall) thermal resistance → lower rating",
      "input": {
        "conductor_material": "cu", "conductor_size": 630,
        "insulation": "xlpe", "voltage_kv": 132,
        "installation": "in_conduit", "num_circuits": 1
      },
      "expected": {
        "base_rating_a": {"lt": 600}
      }
    },
    {
      "name": "3-core submarine: armour losses",
      "source": "IEC 60287-1-1 §2.4.2.5, CIGRE TB 880 Case 2",
      "input": {
        "conductor_material": "cu", "conductor_size": 630,
        "insulation": "xlpe", "voltage_kv": 30,
        "bonding": "both_ends", "num_circuits": 1
      },
      "expected": {
        "preset_used":          {"not_null": true},
        "sheath.lambda1":       {"gt": 0.1},
        "iteration.converged":  {"value": true}
      }
    },
    {
      "name": "Custom: no preset fallback",
      "source": "Estimated geometry when no preset matches",
      "input": {
        "conductor_material": "cu", "conductor_size": 500,
        "insulation": "xlpe", "voltage_kv": 110,
        "cable_preset": "auto", "num_circuits": 1
      },
      "expected": {
        "preset_used":          {"value": null},
        "base_rating_a":        {"gt": 0},
        "iteration.converged":  {"value": true}
      }
    },
    {
      "name": "66kV 300Cu preset matches",
      "source": "Preset auto-matching by voltage/size/material/insulation",
      "input": {
        "conductor_material": "cu", "conductor_size": 300,
        "insulation": "xlpe", "voltage_kv": 66,
        "num_circuits": 1
      },
      "expected": {
        "preset_used":          {"not_null": true},
        "conductor.diameter_mm": {"value": 20.5, "abs": 0.1},
        "base_rating_a":        {"range": [400, 700]}
      }
    },
    {
      "name": "11kV 240Cu: low voltage preset",
      "source": "Preset for 11kV distribution cable",
      "input": {
        "conductor_material": "cu", "conductor_size": 240,
        "insulation": "xlpe", "voltage_kv": 11,
        "num_circuits": 1
      },
      "expected": {
        "preset_used":          {"not_null": true},
        "dielectric.Wd_w_m":   {"lt": 0.05},
        "base_rating_a":        {"range": [350, 550]}
      }
    }
  ]
}
